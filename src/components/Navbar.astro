---
import iconFlame from "../../public/assets/icon_flama.jpg";

// Navbar estilo Mac OS clásico
const menuItems = [
  { icon: iconFlame },
  { label: "File", href: "#" },
  { label: "Edit", href: "#" },
  { label: "View", href: "#" },
  { label: "Special", href: "#" },
];
---

<nav class="mac-menubar">
  <div class="mac-menubar-content">
    <div class="mac-menubar-left">
      <img src={iconFlame.src} class="max-h-7" />
      {
        menuItems.map((item) => (
          <a href={item.href} class="mac-menu-item">
            {item.label}
          </a>
        ))
      }
    </div>
    <div class="mac-menubar-right">
      <span class="mac-clock"></span>
    </div>
  </div>
</nav>

<style>
  .mac-menubar {
    background: rgb(232, 232, 232);
    border-bottom: 2px solid black;
  }

  .mac-menubar-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 8px;
    height: 28px;
  }

  .mac-menubar-left {
    display: flex;
  }

  .mac-menu-item {
    color: black;
    text-decoration: none;
    font-size: 14px;
    padding: 4px 8px;
    display: flex;
    align-items: center;
    gap: 4px;
    transition: all 0.1s;
    font-weight: 400;
  }

  .mac-menu-item:hover {
    background: black;
    color: white;
  }

  .mac-menu-icon {
    font-size: 16px;
    line-height: 1;
  }

  .mac-menubar-right {
    display: flex;
    align-items: center;
  }

  .mac-clock {
    font-size: 14px;
    color: black;
    font-weight: 400;
  }
</style>

<script>
  function updateClock() {
    const currentTime: string = new Date().toLocaleTimeString("en-US", {
      hour: "2-digit",
      minute: "2-digit",
      hour12: true,
    });

    const horaNav = document.querySelector(".mac-clock") as HTMLElement;
    if (horaNav) {
      horaNav.innerText = currentTime;
    }
  }

  updateClock();

  setInterval(updateClock, 6000);
</script>

---
import WindowModal from "./WindowModal.astro";
---

<section
  class="mt-5 flex flex-col flex-wrap max-h-[90vh] gap-4 max-w-6 pl-6 text-center"
>
  <button
    class="max-w-25 flex flex-col items-center cursor-pointer"
    data-open="about-window"
  >
    <img class="w-12" src="/assets/aboutMeIcon.svg" alt="meIcon" />
    <p class="bg-amber-50 p-1">Sobre Mí</p>
  </button>
  <div class="w-25 flex flex-col items-center">
    <img class="w-12" src="/assets/folderIcon.svg" alt="meIcon" />
    <p class="bg-amber-50 p-1">Mis Cosas</p>
  </div>
  <div class="w-25 flex flex-col items-center">
    <img class="w-12" src="/assets/certsIcon.svg" alt="meIcon" />
    <p class="bg-amber-50 p-1">Certificaciones</p>
  </div>
  <div class="w-25 flex flex-col items-center">
    <img class="w-12" src="/assets/projectsIcon.svg" alt="meIcon" />
    <p class="bg-amber-50 p-1">Mis Proyectos</p>
  </div>
  <div class="w-25 flex flex-col items-center">
    <img class="w-12" src="/assets/terminalIcon.svg" alt="meIcon" />
    <p class="bg-amber-50 p-1">Terminal</p>
  </div>
  <div class="w-25 flex flex-col items-center">
    <img class="w-12" src="/assets/pdfIcon.svg" alt="meIcon" />
    <p class="bg-amber-50 p-1">CV - Iván Duarte Herrera</p>
  </div>
  <div class="w-25 flex flex-col items-center">
    <img class="w-12" src="/assets/emailIcon.svg" alt="meIcon" />
    <p class="bg-amber-50 p-1">DH-MAIL</p>
  </div>
</section>

<WindowModal id="about-window" title="Sobre Mí">
  <div class="flex gap-8 items-start mt-10">
    <!-- Foto con efecto de moneda girando y nombre -->
    <div class="flex flex-col items-center">
      <div class="coin-container">
        <div class="coin">
          <div class="coin-face coin-front">
            <img
              src="/assets/perfil1.png"
              alt="Perfil 8bit"
              class="w-full h-full object-cover rounded-full"
            />
          </div>
          <div class="coin-face coin-back">
            <img
              src="/assets/perfil2.png"
              alt="Perfil real"
              class="w-full h-full object-cover rounded-full"
            />
          </div>
        </div>
      </div>
      <p class="text-center mt-3 text-xl">Iván Duarte Herrera</p>
    </div>

    <!-- Texto descriptivo -->
    <div class="flex-1">
      <p class="mb-3 leading-relaxed text-2xl">Ingeniero en Informática</p>
      <p class="mb-3 leading-relaxed text-xl">
        DevOps y Desarrollo de software.
      </p>
      <p class="mb-3 leading-relaxed text-base">
        Ingeniero en Informática con orientación al desarrollo de software,
        plataformas cloud y prácticas DevOps, con experiencia en desarrollo
        full-stack, despliegue de aplicaciones en entornos cloud, automatización
        CI/CD, contenedores Docker y trabajo con arquitecturas monolíticas y de
        microservicios
      </p>
    </div>
  </div>
</WindowModal>

<style>
  .coin-container {
    perspective: 1000px;
    width: 180px;
    height: 180px;
    flex-shrink: 0;
  }

  .coin {
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
    animation: coinFlip 8s infinite cubic-bezier(0.45, 0.05, 0.55, 0.95);
  }

  .coin-face {
    position: absolute;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    border-radius: 50%;
    border: 3px solid #000;
    overflow: hidden;
  }

  .coin-front {
    transform: rotateY(0deg);
  }

  .coin-back {
    transform: rotateY(180deg);
  }

  @keyframes coinFlip {
    0%,
    70% {
      transform: rotateY(0deg);
    }
    85%,
    88% {
      transform: rotateY(180deg);
    }
    100% {
      transform: rotateY(360deg);
    }
  }
</style>

<WindowModal id="projects-window" title="Mis Proyectos">
  <p>Lista de proyectos...</p>
</WindowModal>

<script>
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll("[data-open]").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const target = (e.target as HTMLElement)
          .closest("[data-open]")
          ?.getAttribute("data-open");
        const modal = document.getElementById(target!);
        modal?.classList.remove("hidden");
        modal?.classList.add("flex");
      });
    });

    // Abrir ventana "Sobre Mí" por defecto al entrar
    const aboutModal = document.getElementById("about-window");
    aboutModal?.classList.remove("hidden");
    aboutModal?.classList.add("flex");
  });
</script>
